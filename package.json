{
  "name": "agro-decision-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:recommendation": "node --import tsx scripts/test-first-stage-recommendation.ts",
    "postinstall": "prisma generate",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node --import tsx scripts/seed-test-plot.ts",
    "db:clear-test": "node --import tsx scripts/clear-test-plot.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.0",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "leaflet": "^1.9.4",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/geojson": "^7946.0.0",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
