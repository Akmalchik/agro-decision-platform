# Application runtime: Supabase transaction pooler (port 6543).
# Keep pgbouncer=true for Prisma and start with one connection per serverless instance.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Prisma CLI only: direct connection, or Supavisor session mode (port 5432)
# when the machine running migrations cannot reach Supabase over IPv6.
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# No NEXT_PUBLIC_* variables are required by the application at this stage.
