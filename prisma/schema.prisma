generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Plot {
  id              String                                  @id @default(uuid()) @db.Uuid
  cadastralNumber String                                  @unique @map("cadastral_number")
  farmName        String                                  @map("farm_name")
  owner           String
  area            Decimal                                 @db.Decimal(12, 2)
  geometry        Unsupported("geometry(Geometry, 4326)")?
  specialization  String?
  taxId           String?                                 @map("tax_id")
  waterSupply     String?                                 @map("water_supply")
  previousCrop    String?                                 @map("previous_crop")
  lastHarvestDate DateTime?                               @map("last_harvest_date") @db.Date
  createdAt       DateTime                                @default(now()) @map("created_at")
  farmId          String?                                 @map("farm_id") @db.Uuid
  farm            Farm?                                   @relation(fields: [farmId], references: [id], onDelete: Restrict, map: "plots_farm_id_fkey")
  soilProfile     SoilProfile?
  recommendations Recommendation[]
  legacyRecommendations LegacyRecommendation[]

  @@index([farmName])
  @@index([taxId])
  @@index([farmId])
  @@index([geometry], type: Gist, map: "plots_geometry_idx")
  @@map("plots")
}

model Farm {
  id        String @id @default(uuid()) @db.Uuid
  taxId     String @unique @map("tax_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  plots     Plot[]

  @@map("farms")
}

model SoilProfile {
  id      String   @id @default(uuid()) @db.Uuid
  plotId  String   @unique @map("plot_id") @db.Uuid
  bonitet Decimal? @db.Decimal(5, 2)
  plot    Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@map("soil_profiles")
}

model Crop {
  id                   String               @id @default(uuid()) @db.Uuid
  code                 String               @unique
  name                 String               @unique
  nameUzLatn           String               @map("name_uz_latn")
  nameUzCyrl           String               @map("name_uz_cyrl")
  nameRu               String               @map("name_ru")
  category             String
  minBonitet           Int                  @map("min_bonitet")
  optimalBonitetMin    Int                  @map("optimal_bonitet_min")
  optimalBonitetMax    Int                  @map("optimal_bonitet_max")
  waterNeed            String               @map("water_need")
  descriptionUzLatn    String               @map("description_uz_latn")
  descriptionUzCyrl    String               @map("description_uz_cyrl")
  descriptionRu        String               @map("description_ru")
  active               Boolean              @default(true)
  productionBalances   ProductionBalance[]
  recommendationItems  RecommendationItem[]
  legacyRecommendations LegacyRecommendation[]

  @@index([category])
  @@map("crops")
}

model ProductionBalance {
  id          String  @id @default(uuid()) @db.Uuid
  cropId      String  @map("crop_id") @db.Uuid
  production  Decimal @db.Decimal(14, 2)
  consumption Decimal @db.Decimal(14, 2)
  selfSupply  Decimal @map("self_supply") @db.Decimal(7, 2)
  deficit     Decimal @db.Decimal(14, 2)
  surplus     Decimal @db.Decimal(14, 2)
  crop        Crop    @relation(fields: [cropId], references: [id], onDelete: Restrict)

  @@index([cropId])
  @@map("production_balances")
}

model Recommendation {
  id                String               @id(map: "recommendations_v2_pkey") @default(uuid()) @db.Uuid
  plotId            String               @map("plot_id") @db.Uuid
  stage             String
  calculatedAt      DateTime             @default(now()) @map("calculated_at")
  algorithmVersion  String               @map("algorithm_version")
  inputBonitet      Decimal              @map("input_bonitet") @db.Decimal(5, 2)
  inputWaterSupply  String               @map("input_water_supply")
  inputPreviousCrop String               @map("input_previous_crop")
  plot              Plot                 @relation(fields: [plotId], references: [id], onDelete: Cascade, map: "recommendations_v2_plot_fkey")
  items             RecommendationItem[]

  @@index([plotId, stage, calculatedAt], map: "recommendations_v2_plot_stage_calculated_idx")
  @@map("recommendations")
}

model RecommendationItem {
  id               String         @id @default(uuid()) @db.Uuid
  recommendationId String         @map("recommendation_id") @db.Uuid
  cropId           String         @map("crop_id") @db.Uuid
  rank             Int
  finalScore       Int            @map("final_score")
  bonitetScore     Int            @map("bonitet_score")
  waterScore       Int            @map("water_score")
  rotationScore    Int            @map("rotation_score")
  status           String
  reasonKeys       Json           @map("reason_keys")
  warningKeys      Json           @map("warning_keys")
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade, map: "recommendation_items_recommendation_fkey")
  crop             Crop           @relation(fields: [cropId], references: [id], onDelete: Restrict, map: "recommendation_items_crop_fkey")

  @@unique([recommendationId, cropId], map: "recommendation_items_recommendation_crop_key")
  @@unique([recommendationId, rank], map: "recommendation_items_recommendation_rank_key")
  @@index([cropId], map: "recommendation_items_crop_idx")
  @@map("recommendation_items")
}

model CropRotationRule {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  previousCropCode   String @map("previous_crop_code")
  nextCropCode       String @map("next_crop_code")
  compatibilityScore Int    @map("compatibility_score")
  status             String
  explanationKey     String @map("explanation_key")

  @@unique([previousCropCode, nextCropCode], map: "crop_rotation_rules_previous_next_key")
  @@map("crop_rotation_rules")
}

model LegacyRecommendation {
  id          String  @id(map: "recommendations_pkey") @db.Uuid
  plotId      String  @map("plot_id") @db.Uuid
  cropId      String  @map("crop_id") @db.Uuid
  score       Decimal @db.Decimal(5, 2)
  explanation String
  plot        Plot    @relation(fields: [plotId], references: [id], onDelete: Cascade, map: "recommendations_plot_id_fkey")
  crop        Crop    @relation(fields: [cropId], references: [id], onDelete: Restrict, map: "recommendations_crop_id_fkey")

  @@unique([plotId, cropId], map: "recommendations_plot_id_crop_id_key")
  @@index([cropId], map: "recommendations_crop_id_idx")
  @@map("legacy_recommendations")
}
